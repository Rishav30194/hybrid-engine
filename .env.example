# Copy to .env.local and fill in your Supabase project values.
# Both are safe to expose in a client bundle (the publishable key is meant for
# clients; Row-Level Security protects the data). Cloud sync stays disabled
# until set. VITE_SUPABASE_ANON_KEY (legacy) is still accepted as a fallback.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
